{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "main-capability",
  "description": "Least-privilege desktop permissions for the SummerFlow main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "dialog:default",
    "log:default",
    "os:default",
    "process:allow-restart",
    "updater:default",
    "opener:default",
    "fs:default",
    "fs:allow-read-text-file",
    "fs:allow-write-text-file",
    "fs:allow-read-dir",
    "fs:allow-remove",
    {
      "identifier": "fs:scope",
      "allow": [
        { "path": "$APPLOCALDATA/backups" },
        { "path": "$APPLOCALDATA/backups/**" },
        { "path": "$APPLOG/**/*" },
        { "path": "$DOCUMENT/**/*.json" },
        { "path": "$DOWNLOAD/**/*.json" },
        { "path": "$DESKTOP/**/*.json" }
      ],
      "deny": [
        { "path": "$APPLOCALDATA/EBWebView/**/*" }
      ]
    }
  ]
}
